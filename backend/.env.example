NODE_ENV=development
PORT=5000

# ===== DATABASE =====
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=12345
DB_NAME=Gishoma
DB_SSL=false

# ===== JWT SECURITY =====
# IMPORTANT: Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be at least 64 characters for security
JWT_ACCESS_SECRET=your-access-secret-minimum-64-characters-change-in-production-now
JWT_REFRESH_SECRET=your-refresh-secret-minimum-64-characters-change-in-production-now
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ===== DATA ENCRYPTION =====
# Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Used for encrypting sensitive student data at rest
ENCRYPTION_KEY=

# ===== BCRYPT =====
# Higher values = more secure but slower (10-12 recommended)
BCRYPT_ROUNDS=12

# ===== BRUTE FORCE PROTECTION =====
# Max login attempts before lockout
MAX_LOGIN_ATTEMPTS=5
# How long to lock account (minutes)
LOCKOUT_DURATION_MINUTES=15

# ===== DEFAULT PASSWORD =====
# Default password assigned to newly created student/teacher accounts
# Users should change this on first login
DEFAULT_PASSWORD=password123

# ===== EMAIL NOTIFICATIONS =====
# SMTP credentials for sending welcome, announcement, and password reset emails
EMAIL=your-email@gmail.com
EMAIL_PASS=your-app-specific-password

# ===== FRONTEND =====
FRONTEND_URL=http://localhost:5173

# ===== LOGGING =====
LOG_DIR=./logs

# ===== RATE LIMITING =====
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
